generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model budget {
  id           String   @id @default(uuid())
  userId       String
  categoryId   String
  monthlyLimit Float
  monthYear    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  category     category @relation(fields: [categoryId], references: [id], onDelete: Cascade, map: "Budget_categoryId_fkey")
  user         user     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Budget_userId_fkey")

  @@unique([userId, categoryId, monthYear], map: "Budget_userId_categoryId_monthYear_key")
  @@index([categoryId], map: "Budget_categoryId_fkey")
}

model category {
  id        String   @id @default(uuid())
  userId    String?
  name      String
  type      String
  icon      String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  budget    budget[]
  transactions transaction[]

  @@index([userId], map: "Category_userId_fkey")
}

model debt {
  id               String    @id @default(uuid())
  userId           String
  title            String
  total_amount     Float
  remaining_amount Float
  dueDate          DateTime?
  status           String    @default("UNPAID")
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  transactions      transaction[]
  user             user          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "Debt_userId_fkey")
}

model portfolio {
  id        String   @id @default(uuid())
  userId    String
  type      String
  symbol    String
  amount    Float
  buyPrice  Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "Portfolio_userId_fkey")
}

model transaction {
  id          String   @id @default(uuid())
  userId      String
  categoryId  String?
  debtId      String?
  type        String
  amount      Float
  date        DateTime
  description String?
  priority    String?
  receiptUrl  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  category    category? @relation(fields: [categoryId], references: [id])
  debt        debt?     @relation(fields: [debtId], references: [id])
  user        user      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([categoryId], map: "Transaction_categoryId_fkey")
  @@index([debtId], map: "Transaction_debtId_fkey")
  @@index([userId], map: "Transaction_userId_fkey")
}

model user {
  id             String    @id @default(uuid())
  email          String    @unique(map: "User_email_key")
  name           String?
  image          String?
  is_premium     Boolean   @default(false)
  premium_expiry DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime    @updatedAt
  password       String?
  budget         budget[]
  transactions   transaction[]
  debts          debt[]
  portfolios     portfolio[]
}
